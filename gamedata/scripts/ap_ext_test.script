local KIT_CONSUMABLES_ITEMS = {
    -- meds (top-tier first)
    { sec = "medkit_scientic",       count = 10 },
    { sec = "medkit_army",           count = 20 },
    { sec = "bandage",               count = 30 },
    { sec = "drug_anabiotic",        count = 5 },
    { sec = "drug_sleepingpills",    count = 30 },
    { sec = "antirad",               count = 20 },
    { sec = "drug_radioprotector",   count = 10 },
    -- food + water
