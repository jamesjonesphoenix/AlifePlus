--- ap_ext_test: MCM debug tools and demo harnesses

local pairs, ipairs, pcall = pairs, ipairs, pcall
local table_sort, table_remove, math_min = table.sort, table.remove, math.min
local math_floor, math_huge = math.floor, math.huge
local string_format, time_global = string.format, time_global
local character_community, IsStalker, IsMonster = character_community, IsStalker, IsMonster
local UnregisterScriptCallback, RegisterScriptCallback = UnregisterScriptCallback, RegisterScriptCallback

local ARTEFACTS = {
    "af_medusa", "af_cristall_flower", "af_fireball",
    "af_electra_sparkler", "af_gravi", "af_gold_fish",
    "af_mincer_meat", "af_eye",
}

local function _tip(msg)
    local actor = db.actor
    if actor then news_manager.send_tip(actor, msg, nil, nil, 5000) end
end

local function _find_nearest_alpha()
    local actor = db.actor
    if not actor then return nil, "Not in game" end
    local sim = alife()
    local actor_se = sim:actor()
    if not actor_se then return nil, "No actor entity" end
    local actor_level = xlevel.get_level_id(actor_se)
    local pos = actor:position()
    local alphas = ap_ext_tracker.get_alphas()
    local total, on_level = 0, 0
    local best_id, best_data, best_dist, best_pos = nil, nil, math_huge, nil
    for npc_id, data in pairs(alphas) do
        total = total + 1
        if data.level_id ~= actor_level then goto skip end
        on_level = on_level + 1
        local se = sim:object(npc_id)
        if not se then goto skip end
        local dist = pos:distance_to(se.position)
        if dist < best_dist then
            best_id = npc_id
            best_data = data
            best_dist = dist
            best_pos = se.position
        end
        ::skip::
    end
    ap_core_debug.debug("[TEST] alpha_search total=%d on_level=%d level_id=%d", total, on_level, actor_level)
    if not best_id then return nil, "No alphas on this level" end
    local squad = xsquad.get_squad_by_member(best_id)
    if not squad then
        ap_core_debug.debug("[TEST] alpha_search no_squad npc_id=%d", best_id)
        return nil, "Alpha squad not found"
    end
    return { id = best_id, data = best_data, dist = best_dist, pos = best_pos, squad = squad }
end

--- @export console
function pull_alpha()
    ap_core_debug.debug("[TEST] pull_alpha pressed")
    local result, reason = _find_nearest_alpha()
    if not result then
        ap_core_debug.debug("[TEST] pull_alpha SKIP %s", reason)
        return _tip(reason)
    end
    local actor = db.actor
    local pos = actor:position()
    local tp = vector():set(pos.x + 10, pos.y, pos.z)
    TeleportSquad(result.squad, tp, actor:level_vertex_id(), actor:game_vertex_id())
    local name = xcreature.get_name(result.id) or "?"
    ap_core_debug.debug("[TEST] pull_alpha OK npc_id=%d squad_id=%d level=%d name=%s dist=%d community=%s",
        result.id, result.squad.id, result.data.level, name,
        math_floor(result.dist), result.squad:get_squad_community())
    _tip("Pulled alpha L" .. result.data.level .. " " .. name .. " from " .. math_floor(result.dist) .. "m")
end

--- @export console
function goto_alpha()
    ap_core_debug.debug("[TEST] goto_alpha pressed")
    local result, reason = _find_nearest_alpha()
    if not result then
        ap_core_debug.debug("[TEST] goto_alpha SKIP %s", reason)
        return _tip(reason)
    end
    db.actor:set_actor_position(result.pos)
    local name = xcreature.get_name(result.id) or "?"
    ap_core_debug.debug("[TEST] goto_alpha OK npc_id=%d squad_id=%d level=%d name=%s dist=%d community=%s",
        result.id, result.squad.id, result.data.level, name,
        math_floor(result.dist), result.squad:get_squad_community())
    _tip("Teleported to alpha L" .. result.data.level .. " " .. name .. " (" .. math_floor(result.dist) .. "m)")
end

local CONSEQUENCE = ap_core_const.CONSEQUENCE
local NEEDS_ARRIVE_KEYS = {
    [CONSEQUENCE.HUNGER_CAMPFIRE] = true, [CONSEQUENCE.SLEEP_CAMPFIRE] = true, [CONSEQUENCE.REST_CAMPFIRE] = true,
    [CONSEQUENCE.HEAL_SHELTER] = true, [CONSEQUENCE.SHELTER_INDOOR] = true, [CONSEQUENCE.SHELTER_OUTDOOR] = true,
    [CONSEQUENCE.MONEY_HARVEST] = true, [CONSEQUENCE.MONEY_HUNT] = true, [CONSEQUENCE.SUPPLY_TRADER] = true,
    [CONSEQUENCE.JOB_OUTPOST] = true, [CONSEQUENCE.JOB_EXPLORE] = true, [CONSEQUENCE.JOB_RESEARCH] = true,
    [CONSEQUENCE.SOCIAL_CAMPFIRE] = true, [CONSEQUENCE.SOCIAL_BASE] = true,
}

--- @export console
function goto_need()
    ap_core_debug.debug("[TEST] goto_need pressed")
    local actor = db.actor
    if not actor then return _tip("Not in game") end
    local sim = alife()
    local actor_community = db.actor:character_community()
    local scripted = ap_core_broker.get_scripted_squads()
    for squad_id, data in pairs(scripted) do
        local rec = ap_core_broker.get_record({ squad_id = squad_id, assigned = true })
        local cons = rec and rec.consequence
        if not NEEDS_ARRIVE_KEYS[cons] then goto skip end
        local squad = sim:object(squad_id)
        if not squad then goto skip end
        if game_relations.is_factions_enemies(actor_community, squad:get_squad_community()) then goto skip end
        local cmd_se = xobject.se(squad:commander_id())
        if not cmd_se then goto skip end
        db.actor:set_actor_position(cmd_se.position)
        local name = cmd_se:character_name()
        ap_core_debug.debug("[TEST] goto_need OK squad=%d need=%s target=%s npc=%s",
            squad_id, cons, data.scripted_target, name)
        _tip("Teleported to " .. name .. " (" .. cons .. " -> " .. data.scripted_target .. ")")
        do return end
        ::skip::
    end
    _tip("No friendly squad filling a need right now")
    ap_core_debug.debug("[TEST] goto_need SKIP no_friendly_need_squad")
end

--- @export console
function spawn_artefact()
    ap_core_debug.debug("[TEST] spawn_artefact pressed")
    local actor = db.actor
    if not actor then
        ap_core_debug.debug("[TEST] spawn_artefact SKIP no_actor")
        return _tip("Not in game")
    end
    local sec = xmath.sample(ARTEFACTS)
    local se = xobject.create_item(sec, actor:id())
    if se then
        ap_core_debug.debug("[TEST] spawn_artefact OK sec=%s", sec)
        _tip("Spawned " .. sec)
    else
        ap_core_debug.debug("[TEST] spawn_artefact FAIL sec=%s", sec)
        _tip("Failed to spawn " .. sec)
    end
end

