    { sec = "vodka_quality",         count = 5 },
}

local function _spawn_kit_items(items, label)
    local id = db.actor:id()
    local spawned, skipped = 0, 0
    for i = 1, #items do
        local item = items[i]
        if not ini_sys:section_exist(item.sec) then
            ap_core_debug.debug("[TEST] %s SKIP missing section=%s", label, item.sec)
            skipped = skipped + 1
            goto continue
        end
        for idx = 1, item.count do
            xobject.create_item(item.sec, id)
        end
        spawned = spawned + 1
        ::continue::
    end
    return spawned, skipped
end

--- Spawn playtest equipment (weapon, armor, backpack, money, fast travel, scorcher off)
--- @export console
function kit_equipment()
    ap_core_debug.debug("[TEST] kit_equipment pressed")
    local actor = db.actor
    if not actor then return _tip("Not in game") end
    local spawned, skipped = _spawn_kit_items(KIT_EQUIPMENT_ITEMS, "kit_equipment")
    actor:give_money(500000)
    ui_options.set("gameplay/fast_travel/state", 2)
    game_fast_travel.update_settings()
    xactor.give_info("drx_sl_brain_scorcher_switch_off")
    _tip(string_format("Kit equipment: %d items, %d skipped + 500k + travel + scorcher off", spawned, skipped))
    ap_core_debug.debug("[TEST] kit_equipment OK spawned=%d skipped=%d", spawned, skipped)
end

