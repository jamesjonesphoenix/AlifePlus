local _path_builder = function(key)
    local tab = _key_to_tab[key]
    return tab and ("ap/" .. tab .. "/" .. key) or nil
end
cfg, get_config, load_config = xmcm.create_config("ap", defaults, _path_builder)

-- functor_ui receives the UI_MCM instance as trailing arg (ui_mcm.script:1435).
-- functor would receive nothing. MCM 1.7.2fix leaves the file-local GUI nil on fresh opens
-- (only Open_to sets it, and Reset_last_opt skips Open_to when last_path is nil), so
-- ui_mcm.get_gui() returns nil. functor_ui sidesteps that bug.
-- MCM keeps file-local opt_temp (pending widget edits) at ui_mcm.script:175. Any widget
-- the user touched before clicking the profile button is still there, and On_Accept at
-- ui_mcm.script:2393 writes opt_temp AFTER our config writes, partially un-applying the
-- profile. On_Discard flushes opt_temp and closes the dialog; same path the Cancel button
-- takes. gui.owner:SetMsg is the same top-of-screen call MCM uses at ui_mcm.script:2528
-- for its built-in "changes done" message; works in main menu and pause menu both.
local function _apply_profile(gui, overrides, msg)
    local config = axr_main.config
    for k, v in pairs(defaults) do
        local path = _path_builder(k)
        if path then
            local val = v
            if overrides and overrides[k] ~= nil then val = overrides[k] end
            config:w_value("mcm", path, val)
        end
    end
    config:save()
    load_config()
    -- Without this, consumer-local caches stay stale until the next on_option_change.
    SendScriptCallback(ap_core_const.CALLBACK.MCM_OPTION_RESTORE_DEFAULT)
    if gui then
        if gui.owner and gui.owner.SetMsg then
            gui.owner:SetMsg(msg, 5)
        end
        -- Close via On_Cancel, not On_Discard. On_Discard calls Reset_opt -> scroll_opt:Clear
        -- at ui_mcm.script:949, which destroys the btn_reset button while its click handler
        -- is still on the stack; C++ dispatcher returns into the freed control and SEH-fires
        -- on some exe builds (e.g. modified vanilla 1.5.3). On_Cancel only calls HideDialog +
        -- Unregister_UI -- scroll_opt children stay alive long enough for the handler to
        -- unwind. Trade-off: opt_temp is not cleared (vanilla Cancel-without-prompt parity).
        -- If the user touched widgets before clicking reset, those edits remain pending and
        -- will be re-applied on the next On_Accept.
        if gui.On_Cancel then
            gui:On_Cancel()
        end
    end
    if db.actor then
        news_manager.send_tip(db.actor, msg, nil, nil, 5000)
    end
end

function btn_reset_all(gui)
    _apply_profile(gui, nil, "AlifePlus: all settings restored to defaults.")
end

function btn_reset_stateless(gui)
    _apply_profile(gui, stateless_overrides, "AlifePlus: stateless defaults applied.")
end

function set_version_text(_anchor, handlers)
    handlers.desc:SetText(_ap_deps.get_version())
end

local function _slide(txt)
    return {
        id = "title", type = "slide", link = "ap_mcm_banner",
        text = txt, size = { 512, 50 }, spacing = 20
    }
end

local function _desc(txt)
    return { id = "desc", type = "desc", text = txt }
end

local function _tag(txt)
    return { id = "tag", type = "desc", text = txt, clr = {180, 150, 140, 110} }
end

local function _check(key)
    return { id = key, type = "check", val = 1, def = defaults[key] }
end

local function _track(key, mn, mx, st)
    return { id = key, type = "track", val = 2, min = mn, max = mx, step = st, def = defaults[key] }
end

local function _list(key, content)
    return { id = key, type = "list", val = 0, def = defaults[key], content = content }
end

