-- Stateless profile: disables the mechanics that mutate trader stocks, area spawn tables,
-- and stash contents. Squads still dispatch and travel; only the payload at the destination
-- is skipped. supply_trader and supply_trader_offmap have arrive_action toggles (gated in
-- ap_ext_consequences_needs.script via _make_on_arrive). stash_loot and stash_fill have no
-- arrive_action split, so the whole consequence flag is off (dispatch and item move bundle
-- at ap_ext_consequences_stash.script:99,213). hunger_campfire, rest_campfire, heal_shelter,
-- job_outpost, social_campfire, social_base have no arrive_action toggle in the current
-- ruleset, so this profile does not gate them.
local stateless_overrides = {
    -- Arrive-action toggles (trade-only; gated in ap_ext_consequences_needs.script:_make_on_arrive)
    consequence_supply_trader_arrive_action_enabled = false,
    consequence_supply_trader_offmap_arrive_action_enabled = false,
    -- Area mutator spawn toggles (the actual spawn-table mutation step)
    mutator_area_conquest_mutate_smart = false,
    mutator_area_swarm_mutate_smart = false,
    mutator_area_infest_mutate_smart = false,
    -- Stash item flows (whole consequence; no arrive-action split exists for stash)
    consequence_stash_loot_enabled = false,
    consequence_stash_fill_enabled = false,
}

