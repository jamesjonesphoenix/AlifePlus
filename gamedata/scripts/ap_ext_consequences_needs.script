--- ap_ext_consequences_needs: Action-only consequences for human needs (14 entries, all 1:1 with cause).

local alife_release_id, xobject, xsmart, xtime, xtrade = alife_release_id, xobject, xsmart, xtime, xtrade
local ap_core_debug, ap_core_broker, ap_core_record, ap_core_consumer = ap_core_debug, ap_core_broker, ap_core_record, ap_core_consumer

local CAUSE = ap_core_const.CAUSE
local CAUSE_CATEGORY = ap_core_const.CAUSE_CATEGORY
local RESULT = ap_core_const.RESULT
local REASON = ap_core_const.REASON
local CONSEQUENCE = ap_core_const.CONSEQUENCE
local ACTION = ap_core_const.ACTION
local PHASE = ap_core_const.CONSEQUENCE_PHASE
local TRACE = ap_core_const.TRACE
local PRE_RELEASE_GULAG = ap_core_const.PRE_RELEASE_GULAG

local LOG_INIT = ap_core_debug.bracket(CAUSE_CATEGORY.NEEDS)

local cfg = ap_core_mcm.cfg

--- Per-need vanilla section predicates. HUNGER reads the engine-side _ITM bucket built by
--- _g.script:Parse_ITM (kind == i_food / i_drink / i_mutant_cooked). HEAL / REST / SOCIAL /
--- OUTPOST read vanilla item_rewards.ltx via xobject.in_reward_set. The curated lists are
--- maintained by Anomaly, not by AP; addons that ship items_*.ltx overlays or set the right
--- kind on new sections are picked up automatically.
local NEED_MATCH = {
    HUNGER  = function(sec) return IsItem("eatable", sec) ~= nil end,
    HEAL    = function(sec) return xobject.in_reward_set(sec, "items_health")
                                or xobject.in_reward_set(sec, "items_bleed") end,
    REST    = function(sec) return xobject.in_reward_set(sec, "items_rad") end,
    SOCIAL  = function(sec) return xobject.in_reward_set(sec, "items_rad") end,
    OUTPOST = function(sec) return xobject.in_reward_set(sec, "items_rad") end,
}

--- Walk online inventory once, release the first item the per-need predicate accepts.
--- alife_release_id is event-queued (anomaly/_g.script:2229-2237 -> alife():release) so mid-
--- iteration calls inside iterate_inventory are safe.
local function _consume(npc_id, need)
    local match = NEED_MATCH[need]
    if not match then return nil end
    local consumed
    xobject.iterate_online_inventory(npc_id, function(_, item)
        local sec = item:section()
        if match(sec) then
            alife_release_id(item:id())
            consumed = sec
            return true
        end
    end)
    return consumed
end

--- Trade visitor inventory against trader at smart. Resolves trader via xsmart.get_trader_at_smart
--- (profile-name match: trader / barman / barmen) then delegates to xtrade.trade for the full
--- vanilla sell+buy cycle (vanilla cost formulas, best_weapon and slot-equipped skipped on sell,
--- best_weapon ammo restocked to buy_sell[3]). Sell phase capped to random(min, max) items per
--- visit so a single trade arrival does not strip the squad to keep_count in one go.
local function _arrive_trade(visitor_go, smart_id)
    local smart_se = smart_id and xobject.se(smart_id)
    local trader_go = smart_se and xsmart.get_trader_at_smart(smart_se)
    if not trader_go then return {}, {} end
    local max_sell = math.random(cfg.consequence_supply_trader_min_items, cfg.consequence_supply_trader_max_items)
    local result = xtrade.trade(visitor_go, trader_go, { max_sell = max_sell })
    return result.sold, result.bought
end

