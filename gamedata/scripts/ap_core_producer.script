--- ap_core_producer: Dispatches cause predicates on engine callbacks
--- Gate chains: radiant (PACER_1->PROTECTION->RATIO->PACER_2->EVAL), reactive (PACER->RATIO->EVAL)
local pairs, tostring, type, unpack = pairs, tostring, type, unpack
local clock, RegisterScriptCallback = os.clock, RegisterScriptCallback

local CALLBACK = ap_core_const.CALLBACK
local CAUSE_TYPE = ap_core_const.CAUSE_TYPE
local cfg = ap_core_mcm.cfg
local hud = ap_core_hud
local hud_collecting = ap_core_hud.collecting
local sr, sx = hud.r, hud.x
local _handlers = {}
local _subscribed = {}
local _reactive_event_limiter = nil

--- Radiant callback sources (built from registrations with cause_type = RADIANT)
local _radiant_callbacks = {}

--- Phase flag: false during on_game_start (subscribe deferred to actor_on_first_update),
--- true after first_update (register() subscribes new callbacks synchronously).
local _first_update_done = false

--- Callbacks that are always on the player's map (actor/npc game_objects only exist online)
local _always_on_map = {
    [CALLBACK.ACTOR_ON_ITEM_USE] = true,
    [CALLBACK.ACTOR_ON_ITEM_TAKE] = true,
    [CALLBACK.NPC_ON_ITEM_TAKE] = true,
    [CALLBACK.X_NPC_MEDKIT_USE] = true,
}

--- Weighted fair share counters for on-map vs off-map ratio enforcement (separate per pipeline)
--- Tables used as mutable ref containers: [1] = count. Allocated once, no GC pressure.
local _radiant_ct = { on = 0, off = 0 }
local _reactive_ct = { on = 0, off = 0 }

--- PACER_1: coarse rate limiter (100ms, ~10/sec). Pure os.clock + comparison, no squad fields.
local _next_pacer1 = 0
local PACER_1_INTERVAL = 0.1

--- PACER_2: budget limiter (cfg.distributor_interval_sec). Only eligible squads consume triggers.
local _next_pacer2 = 0

--- GATE: RATIO (radiant 3/4, reactive 2/3)
--- @complexity O(1) | 0 luabind
--- @param on_map boolean true = on-map, false = off-map
--- @param ct table { on=N, off=N } mutable counter pair (one per pipeline, allocated once)
--- @return boolean true = allowed, false = blocked
local function _alife_ratio_gate(on_map, ct)
    if ct.on + ct.off >= 32768 then
        ct.on = 0
        ct.off = 0
    end
    local gs = cfg.alife_ratio
    if gs == 0 then return true end

    if gs > 0 then
        if on_map then
            ct.on = ct.on + 1
            return true
        end
        if ct.off * gs <= (10 - gs) * ct.on then
            ct.off = ct.off + 1
            return true
        end
        return false
    end

    local ags = -gs
    if not on_map then
        ct.off = ct.off + 1
        return true
    end
    if ct.on * ags <= (10 - ags) * ct.off then
        ct.on = ct.on + 1
        return true
    end
    return false
end

--- GATE: PACER-REACTIVE (reactive 1/3)
--- @complexity O(1) | 0 luabind (os.clock is Lua C API, not luabind)
local function _reactive_pacer_gate(callback_type)
    if not _reactive_event_limiter then
        _reactive_event_limiter = xttltable.create_token_bucket({ capacity = 1, rate = 1 / ap_core_const.REACTIVE_EVENT_INTERVAL_SEC })
    end
    return _reactive_event_limiter:acquire(callback_type)
end


local function _find_handler_index_by_handler(entries, handler)
    for i = 1, #entries do
        if entries[i].handler == handler then return i end
    end
    return nil
end

-- Check structural invariant: radiant and reactive causes must not share a callback
local function _check_cross_type(cause_type, callback)
    if cause_type == CAUSE_TYPE.REACTIVE and _radiant_callbacks[callback] then
        return "reactive cause on radiant callback"
    end
    if cause_type == CAUSE_TYPE.RADIANT and _handlers[callback] and not _radiant_callbacks[callback] then
        return "radiant cause on reactive callback"
    end
    return nil
end

--- Publish a cause result. Rate-limit is enforced upstream (pre-handler check on entry.category
--- in _eval_*); by the time we reach here the publish is guaranteed to go through. Increment
--- counter keyed on entry.category so the next pre-check sees the +1.
local function _try_publish(on_map, result, trace, category, cause_type)
    result._trace = trace
    result.cause_type = cause_type
    ap_core_util.event_publish(result.cause, result)
    if hud_collecting() then hud.inc_pub(cause_type) end
    ap_core_debug.debug("[PRODUCER] PUBLISHED cause=%s category=%s sq=%s on_map=%s level=%s",
        result.cause, category, result.squad_id, on_map, result.level_id)
end

--- Evaluate all reactive cause handlers for a callback that passed all gates.
--- Pre-checks per-handler category rate-limit before running predicate (skip wasted work on
--- rate-blocked categories). Predicates self-observe their post-decision payload-build under
--- the picked cause; producer calls handler directly.
--- @param handlers table Indexed array of registered handlers for this callback
--- @param on_map boolean|nil On-map status for ratio logging
-- Run one reactive handler; publish on cause, classify on non-publishing rejection.
-- observe() wraps the predicate so every call logs name, code, reason, timing when DEBUG on; passthrough otherwise.
-- @complexity O(1) | 0 luabind (delegates to handler)
local function _try_one_reactive(on_map, entry, args, sc)
    local trace = ap_core_debug.trace()
    local result = ap_core_debug.observe(trace, entry.name, entry.handler, unpack(args))
    if sc then sx.causes = sx.causes + 1 end
    if not result then return end
    if result.cause then
        _try_publish(on_map, result, trace, entry.category, entry.cause_type)
        return
    end
    if sc then hud.classify_cause(result, false) end
end

local function _eval_reactive_handlers(handlers, on_map, ...)
    -- Lua 5.1 vararg fan-out: we dispatch the same ... to N handlers in the loop below.
    -- Capturing {...} once + unpack(args) per handler is the only way to preserve args
    -- across loop iterations. Allocation is ~50us/sec in dense combat; acceptable cost
    -- for reactive pipeline fan-out.
    local args = {...}
    local sc = hud_collecting()
    for i = 1, #handlers do
        _try_one_reactive(on_map, handlers[i], args, sc)
    end
end

--- Cascade buffer for radiant entries. Maintained write-through by register() (append on new,
--- replace in place on re-register). Shuffled in-place per tick; avoids per-tick allocation.
local _cascade_buf = {}
local math_random = math.random

--- Replace the entry in _cascade_buf whose handler ref matches. Used by register() on re-register.
local function _replace_cascade_entry(handler, entry)
    for i = 1, #_cascade_buf do
        if _cascade_buf[i].handler == handler then
            _cascade_buf[i] = entry
            return
        end
    end
end

--- Cascade through radiant generators in random order. Stop on first publish.
--- Per-cause check budget is reset here and consumed inside generators per cause attempt.
--- Predicates self-gate against their per-category cause-rate budget; producer doesn't.
-- Run one radiant cascade entry; publish on cause (caller breaks), classify on non-publishing.
-- observe() wraps the cascade entry so every call logs name, code, reason, timing when DEBUG on; passthrough otherwise.
-- @complexity O(1) | 0 luabind (delegates to handler)
local function _try_one_radiant(on_map, squad, entry, sc)
    local trace = ap_core_debug.trace()
    local result = ap_core_debug.observe(trace, entry.name, entry.handler, squad)
    if sc then sr.causes = sr.causes + 1 end
    if not result then return false end
    if result.cause then
        _try_publish(on_map, result, trace, entry.category, entry.cause_type)
        return true
    end
    if sc then hud.classify_cause(result, true) end
    return false
end

local function _eval_radiant_cascade(on_map, squad)
    local cascade_size = #_cascade_buf
    for i = cascade_size, 2, -1 do
        local j = math_random(i)
        if j ~= i then _cascade_buf[i], _cascade_buf[j] = _cascade_buf[j], _cascade_buf[i] end
    end
    local sc = hud_collecting()
    for i = 1, cascade_size do
        if _try_one_radiant(on_map, squad, _cascade_buf[i], sc) then break end
    end
end

--- Radiant callback handler
--- Gates: PACER_1(1/4) -> is_protected(2/4) -> RATIO(3/4) -> PACER_2(4/4) -> EVAL(cascade)
--- Counters in each gate count what the gate BLOCKED (not what passed). events is input count.
local function _on_radiant(squad)
    if #_cascade_buf == 0 then return end
    local sc = hud_collecting()
    if sc then sr.events = sr.events + 1 end
    -- Gate 1: PACER_1 (100ms coarse limiter, pure clock + comparison)
    local now = clock()
    if now < _next_pacer1 then
        if sc then sr.pacer1 = sr.pacer1 + 1 end
        return
    end
    _next_pacer1 = now + PACER_1_INTERVAL
    -- Gate 2: is_protected (full eligibility check)
    local protected, reason, detail, name = ap_core_broker.is_protected(squad)
    if protected then
        -- Gate the log: name is nil for owner/scripted/active_role/task_target rejects,
        -- so squad:section_name() would fire on every reject when DEBUG is off.
        if ap_core_debug.enabled() then
            ap_core_debug.debug("[PRODUCER.RADIANT] PROTECTED squad=%d reason=%s detail=%s name=%s",
                squad.id, reason or "?", detail or "?", name or squad:section_name() or "?")
        end
        if sc then sr.protected = sr.protected + 1 end
        return
    end
    -- Gate 3: RATIO
    local on_map = squad.online
    if not _alife_ratio_gate(on_map, _radiant_ct) then
        ap_core_debug.debug("[PRODUCER.RADIANT] ALIFE_RATIO_BLOCKED on_map=%s alife_ratio=%d on=%d off=%d sq=%s",
            tostring(on_map), cfg.alife_ratio, _radiant_ct.on, _radiant_ct.off, squad.id)
        if sc then sr.ratio = sr.ratio + 1 end
        return
    end
    -- Gate 4: PACER_2 (budget limiter, every trigger produces an EVAL)
    if now < _next_pacer2 then
        if sc then sr.pacer2 = sr.pacer2 + 1 end
        return
    end
    _next_pacer2 = now + cfg.distributor_interval_sec
    -- EVAL cascade
    _eval_radiant_cascade(on_map, squad)
end

--- Resolve on-map status for a reactive callback from known-online callbacks or squad.online
-- @complexity O(1) | 0 luabind
local function _resolve_on_map(callback_type, first_arg)
    local on_map = _always_on_map[callback_type]
    if on_map ~= nil then return on_map end
    if first_arg then return first_arg.online end
    return nil
end

--- Reactive entry point (~6.5/sec)
--- Gates: PACER(1/3) -> RATIO(2/3) -> EVAL(3/3)
--- Counters in each gate count what the gate BLOCKED (not what passed). events is input count.
local function _on_reactive(callback_type, ...)
    local handlers = _handlers[callback_type]
    if not handlers or #handlers == 0 then return end
    local sc = hud_collecting()

    if sc then sx.events = sx.events + 1 end
    if not _reactive_pacer_gate(callback_type) then
        if sc then sx.pacer = sx.pacer + 1 end
        return
    end

    local first_arg = select(1, ...)
    local on_map = _resolve_on_map(callback_type, first_arg)
    if on_map ~= nil and not _alife_ratio_gate(on_map, _reactive_ct) then
        ap_core_debug.debug("[PRODUCER.REACTIVE] ALIFE_RATIO_BLOCKED callback=%s alife_ratio=%d on=%d off=%d",
            callback_type, cfg.alife_ratio, _reactive_ct.on, _reactive_ct.off)
        if sc then sx.ratio = sx.ratio + 1 end
        return
    end
    _eval_reactive_handlers(handlers, on_map, ...)
end

local function _create_reactive_dispatcher(callback)
    return function(...) _on_reactive(callback, ...) end
end

local _dispatchers = {}

--- Late-bind subscribe: attach engine callback for a single (callback, cause_type) pair.
--- Called from register() after actor_on_first_update. No-op if already subscribed.
local function _subscribe_late(callback, cause_type)
    if _subscribed[callback] then return end
    if cause_type == CAUSE_TYPE.RADIANT then
        RegisterScriptCallback(callback, _on_radiant)
    else
        local dispatcher = _create_reactive_dispatcher(callback)
        _dispatchers[callback] = dispatcher
        RegisterScriptCallback(callback, dispatcher)
    end
    _subscribed[callback] = true
    ap_core_debug.debug("[PRODUCER.LATE_BIND] subscribed callback=%s type=%s", callback, cause_type)
end

--- Subscribe radiant (shared _on_radiant) and reactive (per-callback _on_reactive)
local function _init_subscriptions()
    for callback in pairs(_radiant_callbacks) do
        if _subscribed[callback] then goto continue end
        RegisterScriptCallback(callback, _on_radiant)
        _subscribed[callback] = true
        ap_core_debug.debug("[PRODUCER.RADIANT] subscribed to callback=%s", callback)
        ::continue::
    end
    for callback in pairs(_handlers) do
        if _subscribed[callback] then goto continue end
        if _radiant_callbacks[callback] then goto continue end
        local dispatcher = _create_reactive_dispatcher(callback)
        _dispatchers[callback] = dispatcher
        RegisterScriptCallback(callback, dispatcher)
        _subscribed[callback] = true
        ap_core_debug.debug("[PRODUCER.REACTIVE] subscribed to callback=%s", callback)
        ::continue::
    end
end

--- Register a cause handler. Predicate publishes specific cause via result.cause; producer
--- never knows the cause string at registration time. Dedup is by handler function ref.
--- Category drives rate-limit grouping (decision 3+15): same-category handlers share one budget.
--- name is the observe() label: a CAUSE.X string for reactive (1:1 with the cause), or a
--- generator-family string for radiant cascades ("needs", "instincts", "area", "stash").
--- Write-through: maintains _handlers, _radiant_callbacks, _cascade_buf synchronously. After
--- actor_on_first_update, also subscribes the engine callback for new callbacks (late-bind).
--- @param config table { callback, cause_type, category, name }
--- @param handler function(trace, ...) Handler function
function register(config, handler)
    if not config or not handler then
        ap_core_debug.err("[PRODUCER] register: missing config or handler")
        return false
    end
    local callback = config.callback
    if not callback then
        ap_core_debug.err("[PRODUCER] register: missing callback")
        return false
    end
    local category = config.category
    if not category then
        ap_core_debug.err("[PRODUCER] register: missing category callback=%s", callback)
        return false
    end
    local name = config.name
    if not name then
        ap_core_debug.err("[PRODUCER] register: missing name callback=%s category=%s", callback, category)
        return false
    end
    local cause_type = config.cause_type or CAUSE_TYPE.REACTIVE
    local conflict = _check_cross_type(cause_type, callback)
    if conflict then
        ap_core_debug.err("[PRODUCER] register: %s callback=%s category=%s name=%s", conflict, callback, category, name)
        return false
    end
    if not _handlers[callback] then
        _handlers[callback] = {}
    end
    local entries = _handlers[callback]
    local existing_idx = _find_handler_index_by_handler(entries, handler)
    local entry = { handler = handler, cause_type = cause_type, category = category, name = name }
    entries[existing_idx or #entries + 1] = entry
    if cause_type == CAUSE_TYPE.RADIANT then
        _radiant_callbacks[callback] = true
        if existing_idx then
            _replace_cascade_entry(handler, entry)
        else
            _cascade_buf[#_cascade_buf + 1] = entry
        end
    end
    if _first_update_done then
        _subscribe_late(callback, cause_type)
    end
    ap_core_debug.info("[PRODUCER] registered: callback=%s type=%s category=%s name=%s", callback, cause_type, category, name)
    return true
end

--- Deferred subscribe: runs on actor_on_first_update after all causes registered.
--- After this point, register() subscribes new callbacks synchronously (late-bind).
local function _on_first_update()
    _init_subscriptions()
    _first_update_done = true
end

--- on_game_start: reset state + register deferred init (no cross-module reads)
function on_game_start()
    _dispatchers = {}
    _subscribed = {}
    _first_update_done = false
    _radiant_ct.on = 0
    _radiant_ct.off = 0
    _reactive_ct.on = 0
    _reactive_ct.off = 0
    _next_pacer1 = 0
    _next_pacer2 = 0
    _reactive_event_limiter = nil
    RegisterScriptCallback(CALLBACK.ACTOR_ON_FIRST_UPDATE, _on_first_update)
    ap_core_debug.info("[PRODUCER] Initialized")
end
