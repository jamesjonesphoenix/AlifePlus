--- Scripted squad update interval (seconds)
UPDATE_SCRIPTED_SQUADS_SEC = 20

--- X-Ray callback names
CALLBACK = {
    -- Cause triggers (via producer)
    SQUAD_ON_UPDATE = "squad_on_update",
    SQUAD_ON_NPC_DEATH = "squad_on_npc_death",
    SQUAD_ON_AFTER_GAME_VERTEX_CHANGE = "squad_on_after_game_vertex_change",
    SQUAD_ON_AFTER_LEVEL_CHANGE = "squad_on_after_level_change",
    X_NPC_MEDKIT_USE = "x_npc_medkit_use",
    ACTOR_ON_ITEM_USE = "actor_on_item_use",
    ACTOR_ON_ITEM_TAKE = "actor_on_item_take",
    NPC_ON_ITEM_TAKE = "npc_on_item_take",
    -- Lifecycle
    ACTOR_ON_FIRST_UPDATE = "actor_on_first_update",
    SAVE_STATE = "save_state",
    LOAD_STATE = "load_state",
    ON_GAME_LOAD = "on_game_load",
    ON_OPTION_CHANGE = "on_option_change",
    -- Behavior (mutators)
    NPC_ON_BEFORE_HIT = "npc_on_before_hit",
    MONSTER_ON_BEFORE_HIT = "monster_on_before_hit",
    -- Loot
    MONSTER_ON_LOOT_INIT = "monster_on_loot_init",
    -- Lifecycle (HUD cleanup + GUI visibility)
    ACTOR_ON_NET_DESTROY = "actor_on_net_destroy",
    GUI_ON_SHOW = "GUI_on_show",
    GUI_ON_HIDE = "GUI_on_hide",
    -- External / non-AP callbacks
    SERVER_ENTITY_ON_REGISTER = "server_entity_on_register",
    SERVER_ENTITY_ON_UNREGISTER = "server_entity_on_unregister",
    SQUAD_ON_NPC_CREATION = "squad_on_npc_creation",
    MCM_OPTION_RESTORE_DEFAULT = "mcm_option_restore_default",
    ACTOR_ON_UPDATE = "actor_on_update",
    MAP_SPOT_MENU_ADD_PROPERTY = "map_spot_menu_add_property",
    MAP_SPOT_MENU_PROPERTY_CLICKED = "map_spot_menu_property_clicked",
    ON_LOCALIZATION_CHANGE = "on_localization_change",
}

--- Cause type classification (radiant = ambient A-Life, reactive = world event response)
--- Pipeline-mechanism axis: how the producer schedules predicate evaluation.
CAUSE_TYPE = { RADIANT = "radiant", REACTIVE = "reactive" }

--- Cause category classification (behavioral axis, parallel to CAUSE_TYPE).
--- What kind of squad behavior the cause represents. Drives the per-category rate-limit
--- counter key and MCM organization. Each cause declares its category at register time and
--- self-gates against its `cause_max_<category>` MCM cap via ap_core_limiter.
--- Future parallel axes (attack/flee, expansive/contracting) get their own enums — never
--- overload CAUSE_CATEGORY. ap_api forces foreign causes to pick from this set.
CAUSE_CATEGORY = {
    REACTIONS     = "category:reactions",
    NEEDS         = "category:needs",
    INSTINCTS     = "category:instincts",
    OPPORTUNITIES = "category:opportunities",
}

--- Radiant cause callbacks (all radiant causes register on these)
RADIANT_CALLBACKS = {
    CALLBACK.SQUAD_ON_UPDATE,
}

--- Reactive callback families (one logical event has multiple engine paths).
--- Cause registers the same predicate against every callback in its family.
HARVEST_CALLBACKS = {
    CALLBACK.ACTOR_ON_ITEM_TAKE,
    CALLBACK.NPC_ON_ITEM_TAKE,
}
WOUNDED_CALLBACKS = {
    CALLBACK.X_NPC_MEDKIT_USE,
    CALLBACK.ACTOR_ON_ITEM_USE,
}

--- Pipeline caps (internal tuning, not MCM).
--- REACTIVE_MAX_CONSEQUENCES_PER_CAUSE: consumer ceiling on consequences fired per reactive cause publish.
--- RADIANT_MAX_SCANS_PER_GENERATOR: ceiling on SCAN reaches inside a single radiant generator
---   invocation (one _on_smart call). RULES rejections stay free; only causes that pass RULES and
---   enter their world SCAN (find_smart / find_squads) consume a slot. Resets every _on_smart call.
REACTIVE_MAX_CONSEQUENCES_PER_CAUSE = 2
RADIANT_MAX_SCANS_PER_GENERATOR = 2

--- Result codes: consequence handler return values (template method phases)
--- Handlers return SUCCESS, FAILED_RULES, FAILED_SCAN, FAILED_ACTION.
--- DISABLED is consumer-only (condition pre-gate, never returned by handlers).
RESULT = {
    SUCCESS = "success",
    FAILED_RULES = "failed_rules",
    FAILED_SCAN = "failed_scan",
    FAILED_ACTION = "failed_action",
    DISABLED = "disabled",
}

--- Trace-level observe result codes (diagnostic, not pipeline flow)
TRACE = {
    OK = "ok",
    NONE = "none",
    EMPTY = "empty",
    NO_SMART = "no_smart",
    NO_SQUADS = "no_squads",
    NO_ENTITY = "no_entity",
    NO_ITEMS = "no_items",
    NO_ARTEFACT = "no_artefact",
    CO_LOCATED = "co_located",
    CHANCE = "chance",
    NO_MSG = "no_msg",
    NO_SENDER = "no_sender",
    SENT = "sent",
    NO_TEMPLATES = "no_templates",
}

--- Distance thresholds (meters)
RADIUS_CLOSE_MAX = 50
RADIUS_DISTANT_MAX = 500

--- Range tiers (meters). Grounded in GSC PersonalEyeRange (EFC design docs) and
--- empirical level geometry measurements (doc/library/modding/level-geometry.md).
--- EyeRange: line-of-sight, local awareness. Opportunities (stash, area).
--- RadioRange: PDA radio for stalkers. Reactions, needs.
--- ScentRange: scent tracking for mutants. Instincts, mutant-only reactions.
RANGE_EYE = 200
RANGE_RADIO = 500
RANGE_SCENT = 500

--- Game-hours to seconds conversion (xtime.game_sec uses seconds; MCM thresholds use hours).
HOURS_TO_SECONDS = 3600

--- Harvest pickup cooldown per artefact section (os.clock seconds, 2 hours)
HARVEST_COOLDOWN_SEC = 7200

--- Map marker type
MARKER_ACTIVE = "blue_location"
MARKER_LINGER_SEC = 60

--- Cause event names. Specific causes are what predicates publish and consequences subscribe to.
--- Reactive (one cause per callback): ALPHA, ALPHAKILL, MASSACRE, SQUADKILL, BASEKILL, WOUNDED, HARVEST.
--- Radiant (one umbrella file -> N specific causes via predicate-side picker): NEEDS family, INSTINCTS family,
--- STASH family, AREA family. Each radiant umbrella publishes only its specific per-action
--- causes; the umbrella name itself is never published or subscribed to as an event.
CAUSE = {
    ALPHA = "cause:alpha",
    ALPHAKILL = "cause:alphakill",
    MASSACRE = "cause:massacre",
    SQUADKILL = "cause:squadkill",
    BASEKILL = "cause:basekill",
    WOUNDED = "cause:wounded",
    HARVEST = "cause:harvest",
    -- NEEDS family (radiant, Hull drive-reduction scoring)
    HUNGER_CAMPFIRE  = "cause:hunger_campfire",
    SLEEP_CAMPFIRE   = "cause:sleep_campfire",
    REST_CAMPFIRE    = "cause:rest_campfire",
    HEAL_SHELTER     = "cause:heal_shelter",
    SHELTER_INDOOR   = "cause:shelter_indoor",
    SHELTER_OUTDOOR  = "cause:shelter_outdoor",
    SUPPLY_TRADER    = "cause:supply_trader",
    SUPPLY_TRADER_OFFMAP = "cause:supply_trader_offmap",
    MONEY_HARVEST    = "cause:money_harvest",
    MONEY_HUNT       = "cause:money_hunt",
    JOB_OUTPOST      = "cause:job_outpost",
    JOB_EXPLORE      = "cause:job_explore",
    JOB_EXPLORE_OFFMAP = "cause:job_explore_offmap",
    JOB_RESEARCH     = "cause:job_research",
    SOCIAL_CAMPFIRE  = "cause:social_campfire",
    SOCIAL_BASE      = "cause:social_base",
    SOCIAL_OFFBASE   = "cause:social_offbase",
    -- INSTINCTS family (radiant Hull-scored)
    SCATTER         = "cause:scatter",
    FEED            = "cause:feed",
    SLUMBER_FIELD   = "cause:slumber_field",
    SLUMBER_LAIR    = "cause:slumber_lair",
    SLUMBER_SURGE   = "cause:slumber_surge",
    ROAM            = "cause:roam",
    PACK            = "cause:pack",
    -- STASH family (radiant MVT timestamps + state-classifier picker)
    STASH_LOOT   = "cause:stash_loot",
    STASH_AMBUSH = "cause:stash_ambush",
    STASH_FILL   = "cause:stash_fill",
    -- AREA family (radiant MVT timestamps + priority-gate picker per alignment)
    AREA_CONQUER = "cause:area_conquer",
    AREA_SWARM   = "cause:area_swarm",
    AREA_INFEST  = "cause:area_infest",
}

