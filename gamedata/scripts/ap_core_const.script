CONSEQUENCE_WINDOW_SEC = 60
GLOBAL_CONSEQUENCE_WINDOW_SEC = 60

--- Reactive event distributor interval (seconds, hardcoded -- per callback type)
REACTIVE_EVENT_INTERVAL_SEC = 1

--- Scripted squad TTL (game seconds, 2 hours)
SCRIPTED_SQUAD_TTL = 7200

