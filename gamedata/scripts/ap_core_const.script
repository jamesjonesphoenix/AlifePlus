--- ap_core_const: Enums, result codes, and shared constants

--- Rate-limit window durations (counts configurable in MCM)
CAUSE_WINDOW_SEC = 60
CONSEQUENCE_WINDOW_SEC = 60
GLOBAL_CONSEQUENCE_WINDOW_SEC = 60

--- Offmap balance window (game seconds). Caps cumulative offmap dispatches per source map.
--- Mirrors framework pattern: pipeline windows are const, only caps are MCM-exposed.
OFFMAP_WINDOW_SEC = 48 * 3600

--- Master rank threshold (per anomaly/configs/creatures/game_relations.ltx:8 rank intervals:
--- expert <= 17499, master >= 17500). Use >= 17499 inclusive to match the engine boundary.
RANK_MASTER = 17499

--- Reactive event distributor interval (seconds, hardcoded -- per callback type)
REACTIVE_EVENT_INTERVAL_SEC = 1

--- Scripted squad TTL (game seconds, 2 hours)
SCRIPTED_SQUAD_TTL = 7200

--- Pre-release gulag durations (game seconds). Squad stays at smart for engine gulag job assignment.
PRE_RELEASE_GULAG_DEFAULT = 300
PRE_RELEASE_GULAG = {
    HUNGER_CAMPFIRE = 1200,
    SLEEP_CAMPFIRE = 10800,
    REST_CAMPFIRE = 1800,
