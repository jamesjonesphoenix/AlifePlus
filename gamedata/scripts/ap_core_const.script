    MASSACRE_LOOT = 1800,
    SQUADKILL_REVENGE = 300,
    BASEKILL_SUPPORT = 1800,
    BASEKILL_FLEE = 3600,
    WOUNDED_HELP = 300,
    WOUNDED_HUNT = 300,
