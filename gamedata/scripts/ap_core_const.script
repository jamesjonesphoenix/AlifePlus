    SOCIAL_OFFBASE = 3600,
    AREA_CONQUER = 7200,
    AREA_SWARM = 14400,
    MASSACRE_SCAVENGE = 1800,
    MASSACRE_INVESTIGATE = 1200,
    MASSACRE_LOOT = 1800,
    SQUADKILL_REVENGE = 300,
    BASEKILL_SUPPORT = 1800,
    BASEKILL_FLEE = 3600,
    WOUNDED_HELP = 300,
    WOUNDED_HUNT = 300,
    HARVEST_ROB = 300,
    HARVEST_HAUNT = 600,
    ALPHAKILL_TARGETED = 300,
    STASH_LOOT = 300,
    STASH_AMBUSH = 7200,
    STASH_FILL = 300,
    FEED = 3600,
    SLUMBER_FIELD = 10800,
    SLUMBER_LAIR = 10800,
    SLUMBER_SURGE = 10800,
