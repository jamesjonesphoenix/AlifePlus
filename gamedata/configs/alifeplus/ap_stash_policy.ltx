; AlifePlus stash policy. Single uniform block (no per-rank). DLTX-overridable.
; Loot flow: for each category, take from stash if squad_count < min, up to min.
; Fill flow: for each category, deposit to stash if squad_count > max, total per event capped by fill_max.
; extras_max: after category-based loot, take top-N additional items from stash by `cost` field.
; Quest / untouchable sections in stash -> whole stash skipped (no loot, no clear). Hardcoded.
; Toolkit-containing stashes -> whole stash skipped only when MCM consequence_stash_loot_skip_crafting on.
; Sell-only categories use 0, 0 (never lootable to squad, never deposited to stash).

[ap_stash_policy]
ammo_slot_3_t1    = 15, 15
ammo_slot_2_t1    = 16, 16
ammo_slot_3_t2    = 0, 0
ammo_slot_2_t2    = 0, 0
ammo_not_equipped = 0, 0
grenade           = 0, 3
grenade_ammo      = 0, 2
medkit            = 2, 3
bandage           = 0, 3
stim              = 0, 2
antirad           = 0, 3
pill              = 0, 3
food              = 0, 3
drink             = 0, 2
weapon            = 0, 0
outfit            = 0, 0
helmet            = 0, 0
artefact          = 0, 0
device            = 0, 0
money             = 0, 0
crafting          = 0, 0
other             = 0, 0
extras_max        = 2
fill_max          = 3
